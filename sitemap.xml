<div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full px-4 md:px-0">
    {% for post in site.posts %}
    <!-- FIXED: Added no-underline to the outer block to kill default browser link decoration -->
    <a href="{{ post.url | relative_url }}" class="block p-6 glass rounded-3xl border border-white/5 hover:border-indigo-500/50 hover:-translate-y-1 transition-all duration-300 group flex flex-col justify-between h-full no-underline">
        <!-- FIXED: w-full container wrap ensures inner elements respect card bounds -->
        <div class="w-full">
            <!-- FIXED: Added gap-2 and shrink-0 to prevent category text from smashing into the date on mobile -->
            <div class="flex justify-between items-center mb-4 gap-2">
                <span class="px-2 py-1 bg-cyan-500/10 text-cyan-400 mono uppercase text-[10px] border border-cyan-500/20 rounded shrink-0">
                    #{{ post.category }}
                </span>
                <time class="text-[10px] text-gray-500 mono shrink-0">{{ post.date | date: "%b %d, %Y" }}</time>
            </div>
            <!-- Title transitions smoothly to white without triggering underlines | FIXED: Added break-words -->
            <h3 class="text-xl font-bold text-gray-200 group-hover:text-white transition-colors mb-3 no-underline break-words">
                {{ post.title }}
            </h3>
            <!-- FIXED: Added break-words to handle long strings/code snippets safely -->
            <p class="text-sm text-gray-400 leading-relaxed mb-6 break-words">
                {{ post.excerpt | strip_html | truncatewords: 20 }}
            </p>
        </div>
        
        <!-- Interactive indicator stays clean and changes colors smoothly -->
        <span class="text-xs text-indigo-400 group-hover:text-indigo-300 font-medium flex items-center gap-1 transition-colors mt-auto">
            Read note <i data-lucide="arrow-right" class="w-3 h-3 group-hover:translate-x-0.5 transition-transform"></i>
        </span>
    </a>
    {% endfor %}
</div>